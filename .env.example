# ============================================
# AWS CREDENTIALS
# ============================================
# INSTRUCTIONS: Copy this file to .env and add your actual AWS credentials
# NEVER commit .env file to GitHub!

# AWS Configuration for Browser
VITE_AWS_ACCESS_KEY_ID=your_aws_access_key_here
VITE_AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
VITE_AWS_REGION=ap-south-1

# ============================================
# API ENDPOINTS
# ============================================
# These will be provided after deployment or by hackathon organizers

# Textract API Endpoint
VITE_TEXTRACT_API_URL=your_textract_api_url_here

# Auth API Endpoint
VITE_AUTH_API_URL=your_auth_api_url_here

# Delta Sync API Endpoint
VITE_SYNC_API_URL=your_sync_api_url_here

# Bedrock Proxy API Endpoint
VITE_BEDROCK_API_URL=your_bedrock_api_url_here

# S3 Bucket Name
VITE_S3_BUCKET_NAME=your_s3_bucket_name_here

# ============================================
# BEDROCK CREDENTIALS (Optional)
# ============================================
# Add if you have a separate Bedrock bearer token

# AWS Bedrock Bearer Token
VITE_AWS_BEARER_TOKEN_BEDROCK=your_bedrock_bearer_token_here

# ============================================
# OPTIONAL SETTINGS
# ============================================

# Use mock authentication (set to 'true' to test without AWS SNS)
# VITE_USE_MOCK_AUTH=true
