/**
 * Modern Job Feed Component with Tailwind CSS
 * 
 * @fileoverview Clean job listings for worker dashboard with enhanced design
 */

import { useState, useEffect } from 'react';
import { useTranslation } from '../../hooks/useTranslation';

/**
 * Job Feed Component
 */
export default function JobFeedTailwind() {
  const { t } = useTranslation();
  const [jobs, setJobs] = useState([]);
  const [loading, setLoading] = useState(true);
  const [searchTerm, setSearchTerm] = useState('');
  const [selectedFilter, setSelectedFilter] = useState('all');

  // Mock job data
  useEffect(() => {
    const mockJobs = [
      {
        id: 1,
        title: 'Construction Worker',
        company: 'BuildTech Solutions',
        location: 'Mumbai, Maharashtra',
        salary: '₹25,000 - ₹35,000',
        type: 'Full-time',
        experience: '2-5 years',
        skills: ['Construction', 'Safety Protocols', 'Heavy Machinery'],
        description: 'Looking for experienced construction workers for residential projects.',
        postedDate: '2 days ago',
        urgent: true,
        verified: true
      },
      {
        id: 2,
        title: 'Electrical Technician',
        company: 'PowerGrid Services',
        location: 'Pune, Maharashtra',
        salary: '₹30,000 - ₹45,000',
        type: 'Full-time',
        experience: '3-7 years',
        skills: ['Electrical Wiring', 'Circuit Design', 'Safety'],
        description: 'Seeking skilled electrical technicians for industrial installations.',
        postedDate: '1 day ago',
        urgent: false,
        verified: true
      },
      {
        id: 3,
        title: 'Plumber',
        company: 'AquaFix Solutions',
        location: 'Delhi, NCR',
        salary: '₹20,000 - ₹30,000',
        type: 'Contract',
        experience: '1-3 years',
        skills: ['Pipe Installation', 'Leak Repair', 'Water Systems'],
        description: 'Immediate requirement for residential plumbing projects.',
        postedDate: '3 hours ago',
        urgent: true,
        verified: false
      },
      {
        id: 4,
        title: 'Painter',
        company: 'ColorCraft Interiors',
        location: 'Bangalore, Karnataka',
        salary: '₹18,000 - ₹28,000',
        type: 'Part-time',
        experience: '1-4 years',
        skills: ['Wall Painting', 'Texture Work', 'Color Mixing'],
        description: 'Looking for skilled painters for interior decoration projects.',
        postedDate: '1 week ago',
        urgent: false,
        verified: true
      },
      {
        id: 5,
        title: 'Welder',
        company: 'SteelWorks Manufacturing',
        location: 'Chennai, Tamil Nadu',
        salary: '₹28,000 - ₹40,000',
        type: 'Full-time',
        experience: '2-6 years',
        skills: ['Arc Welding', 'MIG Welding', 'Metal Fabrication'],
        description: 'Experienced welders needed for manufacturing operations.',
        postedDate: '5 days ago',
        urgent: false,
        verified: true
      }
    ];

    setTimeout(() => {
      setJobs(mockJobs);
      setLoading(false);
    }, 1000);
  }, []);

  // Filter jobs based on search and filter
  const filteredJobs = jobs.filter(job => {
    const matchesSearch = job.title.toLowerCase().includes(searchTerm.toLowerCase()) ||
                         job.company.toLowerCase().includes(searchTerm.toLowerCase()) ||
                         job.location.toLowerCase().includes(searchTerm.toLowerCase());
    
    const matchesFilter = selectedFilter === 'all' || 
                         (selectedFilter === 'urgent' && job.urgent) ||
                         (selectedFilter === 'verified' && job.verified) ||
                         job.type.toLowerCase() === selectedFilter;
    
    return matchesSearch && matchesFilter;
  });

  if (loading) {
    return (
      <div className="flex items-center justify-center py-16">
        <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-primary-500"></div>
        <span className="ml-3 text-gray-600">{t('common:messages.loading', 'Loading...')}</span>
      </div>
    );
  }

  return (
    <div className="space-y-6">
      {/* Header */}
      <div className="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <h2 className="text-2xl font-bold text-gray-900">
            {t('jobs:title', 'Available Jobs')}
          </h2>
          <p className="text-gray-600 mt-1">
            {filteredJobs.length} {filteredJobs.length === 1 ? 'job' : 'jobs'} found
          </p>
        </div>
      </div>

      {/* Search and Filters */}
      <div className="flex flex-col sm:flex-row gap-4">
        {/* Search */}
        <div className="flex-1">
          <div className="relative">
            <svg className="absolute left-3 top-1/2 transform -translate-y-1/2 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              placeholder={t('jobs:searchPlaceholder', 'Search for jobs...')}
              value={searchTerm}
              onChange={(e) => setSearchTerm(e.target.value)}
              className="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
            />
          </div>
        </div>

        {/* Filters */}
        <div className="flex gap-2">
          {[
            { value: 'all', label: 'All Jobs' },
            { value: 'urgent', label: 'Urgent' },
            { value: 'verified', label: 'Verified' },
            { value: 'full-time', label: 'Full-time' },
            { value: 'part-time', label: 'Part-time' }
          ].map((filter) => (
            <button
              key={filter.value}
              onClick={() => setSelectedFilter(filter.value)}
              className={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                selectedFilter === filter.value
                  ? 'bg-primary-100 text-primary-700 border border-primary-200'
                  : 'bg-white text-gray-700 border border-gray-300 hover:bg-gray-50'
              }`}
            >
              {filter.label}
            </button>
          ))}
        </div>
      </div>

      {/* Job Cards */}
      <div className="space-y-4">
        {filteredJobs.length === 0 ? (
          <div className="text-center py-16">
            <svg className="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <h3 className="mt-4 text-lg font-medium text-gray-900">No jobs found</h3>
            <p className="mt-2 text-gray-500">Try adjusting your search or filters</p>
          </div>
        ) : (
          filteredJobs.map((job) => (
            <JobCard key={job.id} job={job} />
          ))
        )}
      </div>
    </div>
  );
}

/**
 * Individual Job Card Component
 */
function JobCard({ job }) {
  const { t } = useTranslation();

  return (
    <div className="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg transition-all duration-200 hover:border-primary-200">
      <div className="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
        {/* Main Content */}
        <div className="flex-1 space-y-3">
          {/* Header */}
          <div className="flex items-start justify-between">
            <div>
              <div className="flex items-center gap-2 mb-1">
                <h3 className="text-xl font-semibold text-gray-900">{job.title}</h3>
                {job.urgent && (
                  <span className="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    Urgent
                  </span>
                )}
                {job.verified && (
                  <svg className="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd" />
                  </svg>
                )}
              </div>
              <p className="text-primary-600 font-medium">{job.company}</p>
            </div>
            <span className="text-sm text-gray-500">{job.postedDate}</span>
          </div>

          {/* Job Details */}
          <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 text-sm">
            <div className="flex items-center text-gray-600">
              <svg className="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {job.location}
            </div>
            <div className="flex items-center text-gray-600">
              <svg className="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
              </svg>
              {job.salary}
            </div>
            <div className="flex items-center text-gray-600">
              <svg className="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {job.type}
            </div>
            <div className="flex items-center text-gray-600">
              <svg className="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
              {job.experience}
            </div>
          </div>

          {/* Description */}
          <p className="text-gray-700 leading-relaxed">{job.description}</p>

          {/* Skills */}
          <div className="flex flex-wrap gap-2">
            {job.skills.map((skill, index) => (
              <span
                key={index}
                className="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800"
              >
                {skill}
              </span>
            ))}
          </div>
        </div>

        {/* Actions */}
        <div className="flex flex-col gap-3 lg:ml-6">
          <button className="px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors">
            {t('jobs:apply', 'Apply Now')}
          </button>
          <button className="px-6 py-3 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors">
            {t('jobs:viewDetails', 'View Details')}
          </button>
        </div>
      </div>
    </div>
  );
}