{
  "name": "shram-setu-infrastructure",
  "version": "1.0.0",
  "description": "AWS CDK infrastructure for shram-Setu",
  "main": "cdk-app.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "deploy": "cdk deploy",
    "deploy:auth": "cdk deploy ShramSetuAuthStack --app 'node cdk-auth-app.js'",
    "deploy:textract": "cdk deploy ShramSetuTextractStack --app 'node cdk-textract-app.js'",
    "deploy:services": "cdk deploy --all --app 'node cdk-services-app.js'",
    "deploy:s3": "cdk deploy ShramSetuS3Stack --app 'node cdk-services-app.js'",
    "deploy:location": "cdk deploy ShramSetuLocationStack --app 'node cdk-services-app.js'",
    "deploy:ratings": "cdk deploy ShramSetuRatingsStack --app 'npx ts-node cdk-ratings-app.ts'",
    "deploy:grievance": "cdk deploy ShramSetuGrievanceStack --app 'npx ts-node cdk-grievance-app.ts' --outputs-file grievance-outputs.json",
    "deploy:jobs": "cdk deploy ShramSetuJobsStack --app 'node cdk-jobs-app.js'",
    "diff": "cdk diff",
    "synth": "cdk synth",
    "destroy": "cdk destroy"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "aws-cdk": "^2.100.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.100.0",
    "constructs": "^10.0.0",
    "source-map-support": "^0.5.21"
  }
}

